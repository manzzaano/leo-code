# leo-code — variables de entorno
# Copia este archivo a .env y descomenta tu provider

# === LLM Providers (elige uno o varios) ===

# Anthropic (Claude Opus/Sonnet/Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4o, GPT-5)
OPENAI_API_KEY=sk-...

# DeepSeek (V4 Pro/Flash — el mejor calidad/precio para código)
DEEPSEEK_API_KEY=sk-...

# Google Gemini (2.5 Pro/Flash)
GOOGLE_API_KEY=...
# GEMINI_API_KEY=...  # alias

# Mistral (Large/Small/Codestral)
MISTRAL_API_KEY=...

# Groq (LPU ultra-fast)
GROQ_API_KEY=...

# Cohere (Command R+)
COHERE_API_KEY=...

# OpenRouter (200+ modelos, un solo API key)
OPENROUTER_API_KEY=...

# Together AI (Llama, Qwen, DeepSeek hosted)
TOGETHER_API_KEY=...

# Azure OpenAI Service
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
# AZURE_OPENAI_API_VERSION=2025-01-01-preview  # default

# AWS Bedrock
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1  # default

# Ollama (local, sin API key — asegúrate de tener ollama corriendo)
# OLLAMA_HOST=http://localhost:11434  # default


# === Infraestructura ===

# Directorio de caché (Qdrant, índices, sesiones)
# LEO_CACHE_DIR=./cache

# Redis para cache L1/L2/L3 (opcional, mejora latencia)
# LEO_REDIS_URL=redis://localhost:6379

# Modelo de embeddings (cambia antes de indexar)
# LEO_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Modelo de reranker cross-encoder
# LEO_RERANKER_MODEL=BAAI/bge-reranker-base

# Baseline de tokens por query para métricas de ahorro
# LEO_BASELINE_TOKENS=20000
